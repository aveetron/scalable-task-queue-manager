# Application (HOST=0.0.0.0 accepts connections from any interface; use for Docker/WSL)
PORT=
HOST=

# Rate limiting (global): THROTTLE_LIMIT requests per THROTTLE_TTL_MS ms per IP (default: 100 per 60000 ms)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Task processor (consumer concurrency: N tasks at a time)
TASK_CONCURRENCY=

# Optional: identify this worker in logs when running multiple workers (e.g. worker-1)
WORKER_ID=

# RabbitMQ (match docker-compose when running broker in Docker)
RABBITMQ_HOST=
RABBITMQ_PORT=
RABBITMQ_VHOST=/
RABBITMQ_DEFAULT_USER=
RABBITMQ_DEFAULT_PASS=

# PostgreSQL
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Large upload (POST /tasks/upload)
UPLOAD_CHUNK_SIZE=5000
UPLOAD_MAX_BYTES=1073741824
UPLOAD_TEMP_DIR=/tmp
